#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "Running pre-commit checks..."

# 1. Type check
echo "→ Generating Prisma client..."
cd server && pnpm prisma:generate
if [ $? -ne 0 ]; then
  echo "✗ Prisma generate failed."
  exit 1
fi

echo "→ Type checking..."
pnpm typecheck
if [ $? -ne 0 ]; then
  echo "✗ Type check failed. Fix TypeScript errors before committing."
  exit 1
fi

# 2. Lint (errors only in pre-commit, not warnings)
echo "→ Linting..."
pnpm lint
if [ $? -ne 0 ]; then
  echo "✗ Lint errors found. Run pnpm lint:fix or fix manually."
  exit 1
fi

echo "✓ All checks passed."
