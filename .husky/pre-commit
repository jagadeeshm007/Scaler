#!/usr/bin/env sh

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

echo "Running pre-commit checks..."

echo "→ Generating Prisma client..."
cd server && pnpm prisma:generate
if [ $? -ne 0 ]; then
  echo "✗ Prisma generate failed."
  exit 1
fi

cd "$ROOT" || exit 1

echo "→ Type checking..."
pnpm typecheck
if [ $? -ne 0 ]; then
  echo "✗ Type check failed. Fix TypeScript errors before committing."
  exit 1
fi

echo "→ Linting..."
pnpm lint
if [ $? -ne 0 ]; then
  echo "✗ Lint errors found. Run pnpm lint:fix or fix manually."
  exit 1
fi

echo "→ Formatting..."
pnpm format:check
if [ $? -ne 0 ]; then
  echo "✗ Prettier check failed. Run pnpm format to fix."
  exit 1
fi

echo "✓ All checks passed."
