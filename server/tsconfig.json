{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@scaler/types": ["../packages/types/src"]
    }
  },
  "include": ["src/**/*", "api/**/*"],
  "ts-node": {
    "files": true
  }
}
